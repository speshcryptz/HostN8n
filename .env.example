# ======================================================
# Railway Environment Variables Configuration
# ======================================================
# You will need to add these variables directly in the
# Railway dashboard for your n8n service.
# ======================================================

# The public URL of your n8n instance (e.g., https://your-project.up.railway.app)
N8N_HOST=your-project.up.railway.app
WEBHOOK_URL=https://your-project.up.railway.app/

# Enforce HTTPS since Railway handles SSL
N8N_PROTOCOL=https

# Generate a random string for encrypting credentials.
# IMPORTANT: DO NOT lose this key, otherwise your saved credentials in n8n will become unreadable!
# You can generate one using `openssl rand -hex 16`
N8N_ENCRYPTION_KEY=replace-with-a-very-long-and-secure-random-string

# ======================================================
# Database Configuration (PostgreSQL on Railway)
# ======================================================
# If you add a PostgreSQL plugin in Railway, these 
# variables will often be provided by Railway automatically.
# Otherwise, manually map them to Railway's Postgres variables.
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=${PGDATABASE}
DB_POSTGRESDB_HOST=${PGHOST}
DB_POSTGRESDB_PORT=${PGPORT}
DB_POSTGRESDB_USER=${PGUSER}
DB_POSTGRESDB_PASSWORD=${PGPASSWORD}
